{
  "layer": "top",
  "position": "top",
  "height": 32,
  "margin-left": 20,
  "margin-right": 20,
  "margin-top": 5,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["custom/weather","clock", "mpris"],
  "modules-right": ["network", "battery","backlight", "pulseaudio", "custom/updates", "custom/notification", "tray"],

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true
  },

 "clock": {
	"format": "{:%H:%M} пЂ— ",
	"format-alt": "{:%A, %B %d, %Y (%R)} пЂ—",
	"tooltip-format": "<tt><small>{calendar}</small></tt>",
	"calendar": {
		"mode"          : "month",
		"mode-mon-col"  : 3,
		"weeks-pos"     : "right",
		"on-scroll"     : 1,
		"on-click-right": "mode",
		"format": {
			"months":     "<span ><b>{}</b></span>",
			"days":       "<span ><b>{}</b></span>",
			"weeks":      "<span ><b>W{}</b></span>",
			"weekdays":   "<span >{}</span>",
			"today":      "<span><b><u>{}</u></b></span>"
		}
	},
	"actions": {
		"on-click-right": "mode",
		"on-click-forward": "tz_up",
		"on-click-backward": "tz_down",
		"on-scroll-up": "shift_up",
		"on-scroll-down": "shift_down"
	}
},

"network": {
    "format-wifi": "п‡«    {essid}",
    "format-ethernet": "у°€Ђ     {ipaddr}",
    "format-disconnected": "вљ  Disconnected",
    "on-click": "nm-connection-editor"
},

"battery": {
    "states": {
        "warning": 30,
        "critical": 15
    },
    "format": "{icon}   {capacity}%",
    "format-charging": "\ue315 {icon} {capacity}%",
    "format-icons": ["п‰„ ", "п‰ѓ ", "п‰‚ ", "п‰Ѓ ", "п‰Ђ "]
},

  "backlight": {
    "device": "intel_backlight",
    "format": "{icon}   {percent}%",
    "format-icons": ["оЋЌ", "оЏ“", "оЏ‘", "оЏЏ", "оЏЋ", "оЏЌ", "оЏЉ", "оЏ€", "оЋ›"],
    "on-scroll-up": "brightnessctl set 1%+",
    "on-scroll-down": "brightnessctl set 1%-",
    "min-length": 6
},

  "tray": {
    "icon-size": 18,
    "spacing": 10
  },
  "pulseaudio": {
        "format": "{icon}   {volume}%",
        "format-muted": "\ueb24",
        "format-icons": {
            "default": ["пЂ¦", "пЂ§", "пЂЁ"]
        },
        "on-click": "pavucontrol"
  },
  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
        "notification": "п‚ў<span foreground='red'><sup>п‘„</sup></span>",
        "none": "п‚ў",
        "dnd-notification": "п‡·<span foreground='red'><sup>п‘„</sup></span>",
        "dnd-none": "п‡·",
        "inhibited-notification": "п‚ў<span foreground='red'><sup>п‘„</sup></span>",
        "inhibited-none": "п‚ў",
        "dnd-inhibited-notification": "п‡·<span foreground='red'><sup>п‘„</sup></span>",
        "dnd-inhibited-none": "п‡·"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
    },
"custom/updates": {
        "format": "{} {icon}",
        "return-type": "json",
        "format-icons": {
            "has-updates": "у±Ќ·",
            "updated": "у°Џ– "
        },
        "exec-if": "which waybar-module-pacman-updates",
        "exec": "waybar-module-pacman-updates --interval-seconds 5 --network-interval-seconds 300 --no-zero-output --tooltip-align-columns",
        "on-click": "foot -e sudo pacman -Syu && killall -SIGUSR2 waybar"
    },
    "mpris": {
    "format": "{player_icon}  {title}",
    "format-paused": "у°Џ¤ {title}",
    "player-icons": {
        "default": "у°Ћ†",
        "spotify": "п†ј"
    },
    "max-length": 30
    },
"custom/weather": {
    "exec": "curl -s 'https://wttr.in/Marklowice?format=%c%t'",
    "interval": 3600,
    "on-click": "xdg-open https://wttr.in/Marklowice"
},
    
}