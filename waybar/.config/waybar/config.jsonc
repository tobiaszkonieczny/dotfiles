{
  "layer": "top",
  "position": "top",
  "height": 32,
  "margin-left": 20,
  "margin-right": 20,
  "margin-top": 5,

  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["group/center"],
  "modules-right": ["group/hardware", "group/tools", "tray"],

  "group/hardware": {
    "orientation": "inherit",
    "modules": [
      "network", "battery","backlight", "pulseaudio"
    ]
  },
  "group/tools": {
    "orientation": "inherit",
    "modules": [
      "custom/updates", "custom/notification"
    ]
  },
  "group/center": {
    "orientation": "inherit",
    "modules": [
      "custom/weather","clock", "mpris"
    ]
  },

  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{name}"
  },

 "clock": {
	"format": "{:%H:%M} ´Çù ",
	"format-alt": "{:%A, %B %d, %Y (%R)} ´Çù",
	"tooltip-format": "<tt><small>{calendar}</small></tt>",
	"calendar": {
		"mode"          : "month",
		"mode-mon-col"  : 3,
		"weeks-pos"     : "right",
		"on-scroll"     : 1,
		"on-click-right": "mode",
		"format": {
			"months":     "<span ><b>{}</b></span>",
			"days":       "<span ><span>{}</span></span>",
			"weeks":      "<span ><b>W{}</b></span>",
			"weekdays":   "<span >{}</span>",
			"today":      "<span><b><u>{}</u></b></span>"
		}
	},
	"actions": {
		"on-click-right": "mode",
		"on-click-forward": "tz_up",
		"on-click-backward": "tz_down",
		"on-scroll-up": "shift_up",
		"on-scroll-down": "shift_down"
	}
},

"network": {
    "format-wifi": "´ç½    {essid}",
    "format-ethernet": "¾░êÇ     {ipaddr}",
    "format-disconnected": "ÔÜá Disconnected",
    "on-click": "nm-connection-editor"
},

"battery": {
    "states": {
        "warning": 30,
        "critical": 15
    },
    "format": "{icon}   {capacity}%",
    "format-charging": "\ue315 {icon} {capacity}%",
    "format-icons": ["´ëä ", "´ëâ ", "´ëé ", "´ëü ", "´ëÇ "]
},

  "backlight": {
    "device": "intel_backlight",
    "format": "{icon}   {percent}%",
    "format-icons": ["¯Äì", "¯Åô", "¯Åæ", "¯ÅÅ", "¯ÅÄ", "¯Åì", "¯Åè", "¯Åê", "¯Äø"],
    "on-scroll-up": "brightnessctl set 1%+",
    "on-scroll-down": "brightnessctl set 1%-",
    "min-length": 6
},

  "tray": {
    "icon-size": 18,
    "spacing": 10
  },
  "pulseaudio": {
        "format": "{icon}   {volume}%",
        "format-muted": "\ueb24",
        "format-icons": {
            "default": ["´Çª", "´Çº", "´Ç¿"]
        },
        "on-click": "pavucontrol"
  },
  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
        "notification": "´éó<span foreground='red'><sup>´æä</sup></span>",
        "none": "´éó",
        "dnd-notification": "´çÀ<span foreground='red'><sup>´æä</sup></span>",
        "dnd-none": "´çÀ",
        "inhibited-notification": "´éó<span foreground='red'><sup>´æä</sup></span>",
        "inhibited-none": "´éó",
        "dnd-inhibited-notification": "´çÀ<span foreground='red'><sup>´æä</sup></span>",
        "dnd-inhibited-none": "´çÀ"
    },
    "return-type": "json",
    "exec-if": "which swaync-client",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true
    },
"custom/updates": {
        "format": "{} {icon}",
        "return-type": "json",
        "format-icons": {
            "has-updates": "¾▒ìÀ",
            "updated": "¾░Åû "
        },
        "exec-if": "which waybar-module-pacman-updates",
        "exec": "waybar-module-pacman-updates --interval-seconds 5 --network-interval-seconds 300 --no-zero-output --tooltip-align-columns",
        "on-click": "foot -e sudo pacman -Syu && killall -SIGUSR2 waybar"
    },
    "mpris": {
    "player": "spotify",
    "format": "{player_icon}  {title}",
    "format-paused": "¾░Åñ {title}",
    "player-icons": {
        "default": "¾░Äå",
        "spotify": "´å╝"
    },
    "max-length": 30
    },
"custom/weather": {
    "exec": "curl -s 'https://wttr.in/Marklowice?format=%c%t'",
    "interval": 3600,
    "on-click": "xdg-open https://wttr.in/Marklowice"
},
    
}